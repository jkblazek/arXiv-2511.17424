{
  "id": "run-seasons",
  "commandLine": "/bin/bash -c '...'",
  "containerSettings": {
    "imageName": "jkblazek/seasons-auction:latest"
  },
  "outputFiles": [
    {
      "filePattern": "outputs/**",
      "destination": {
        "container": {
          "containerUrl": "https://jauctionblob.blob.core.windows.net/results?"
        }
      },
      "uploadOptions": {
        "uploadCondition": "taskCompletion"
      }
    }
  ]
}
