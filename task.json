{
  "id": "run-seasons",
  "commandLine": "/bin/bash -lc 'mkdir -p outputs && julia /app/seasons.jl && cp -r prices.dat time state outputs/ 2>/dev/null || true'",
  "containerSettings": {
    "imageName": "jkblazek/seasons-auction:latest"
  },
  "outputFiles": [
    {
      "filePattern": "outputs/**",
      "destination": {
        "container": {
          "containerUrl": "https://jauctionblob.blob.core.windows.net/results?<SAS_TOKEN>"
        }
      },
      "uploadOptions": {
        "uploadCondition": "taskCompletion"
      }
    }
  ]
}
